ENVIRONMENT=development
DEBUG=false
APP_NAME=api-gateway
HOST=0.0.0.0
PORT=8080
API_PREFIX=/api/v1

DATABASE_URL=postgresql+asyncpg://hypothesis-factory:hypothesis-factory@localhost:5432/hypothesis-factory

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

UPLOAD_DIR=../ml_worker/uploads
REPORT_DIR=../ml_worker/reports

CORS_ORIGINS=["*"]